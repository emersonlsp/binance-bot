# Collector target
EXCHANGE=binance
SYMBOL=BTCBRL
DEPTH_LEVELS=10

# Collector runtime
SNAPSHOT_INTERVAL_SECONDS=2
RECONNECT_DELAY_SECONDS=3
FLUSH_INTERVAL_SECONDS=5
MAX_ROWS_PER_FILE=10000
BASE_DATA_DIR=data/raw
UPDATE_GAP_SECONDS_THRESHOLD=10
SNAPSHOT_GAP_SECONDS_THRESHOLD=120

# Binance credentials (optional for public market data collector)
BINANCE_API_KEY=
BINANCE_API_SECRET=
RECV_WINDOW_MS=5000

# MT5 candle collector (regime context)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
MT5_SYMBOL=BTCUSD
MT5_TIMEFRAMES=M1,M5,M15,H1
MT5_CANDLES_PER_TIMEFRAME=20000
